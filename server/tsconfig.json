{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/**/*"],
  "exclude": [
    "node_modules", 
    "dist",
    "src/app.ts",
    "src/server.ts",
    "src/modules/market/market.controller.ts",
    "src/modules/market/market.routes.ts",
    "src/modules/user/order.controller.ts",
    "src/modules/user/order.history.controller.ts",
    "src/services/SimulatorService.ts"
  ]
}
